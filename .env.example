# Copy this file to .env and fill values.
INPUT_DIR=../ftp_downloads/mp3
OUTPUT_DIR=output
DATA_DIR=data
REPORT_CSV=output/enrichment_report.csv
FINAL_CSV=output/final_enriched_tags.csv
FINAL_NO_BLANKS=true
FINAL_MISSING_VALUE=not listed in free sources
# Optional host-only override used by `python main.py` when INPUT_DIR must stay
# container-relative for manual docker commands.
HOST_INPUT_DIR=
DRY_RUN=true
WRITE_TAGS=false
WRITE_COVER_ART=false
RESUME=true
LIMIT=
SUPPORTED_EXTENSIONS=.mp3,.m4a,.mp4,.aac,.flac
REQUIRED_TAGS=title,artist,album,year,genre,subgenre,mood,bpm,key,language,track_number,disc_number,cover_art
MIN_FIELD_CONFIDENCE=0.65
MIN_WRITE_CONFIDENCE=0.82
FILL_UNKNOWN_VALUES=false
TAG_CREATOR_CPU_THREADS=2
TAG_CREATOR_DOCKER_CPUS=4
# Parallel worker threads across files (blank = min(8, CPU count)).
WORKER_THREADS=6
# Optional: copy each original file here before writing tags, and re-read to verify.
BACKUP_DIR=
VERIFY_AFTER_WRITE=false
ENABLED_PROVIDERS=local_cleanup,itunes,deezer,wikidata,essentia_features,essentia_discogs_effnet,musicnn_mtg_jamendo,clap_zero_shot,web_discovery,rules_inference,acoustid,musicbrainz,lastfm,discogs,cover_art_archive
# PROVIDER_WEIGHTS / RATE_LIMITS are merged over built-in defaults, so you only
# need to list the ones you want to override.
PROVIDER_WEIGHTS=itunes:0.78,deezer:0.74,wikidata:0.52,essentia_features:0.90,essentia_discogs_effnet:0.88,musicnn_mtg_jamendo:0.88,clap_zero_shot:0.86,web_discovery:0.70,rules_inference:0.82,sonoteller:0.94,acoustid:0.95,musicbrainz:0.90,spotify:0.82,lastfm:0.62,discogs:0.76,genius:0.45,cover_art_archive:0.80
RATE_LIMITS=itunes:0.15,deezer:0.25,wikidata:0.35,essentia_features:0.00,essentia_discogs_effnet:0.00,musicnn_mtg_jamendo:0.00,clap_zero_shot:0.00,web_discovery:0.60,sonoteller:1.00,musicbrainz:1.10,cover_art_archive:0.25,spotify:0.10,lastfm:0.25,discogs:1.10,acoustid:0.35,genius:0.25
HYBRID_MODE=true
FREE_STAGE_PROVIDERS=local_cleanup,itunes,deezer,wikidata,acoustid,musicbrainz,lastfm,discogs,cover_art_archive
LOCAL_AI_STAGE_PROVIDERS=essentia_features,essentia_discogs_effnet,musicnn_mtg_jamendo,clap_zero_shot
WEB_STAGE_PROVIDERS=web_discovery,rules_inference
PAID_STAGE_PROVIDERS=
PAID_ONLY_IF_MISSING=true
# Hard cap on paid-provider calls per run (blank = unlimited). Also --max-paid-calls.
MAX_PAID_CALLS=0
# Per-run cap on web_discovery page fetches (0 = unlimited).
WEB_MAX_FETCHES_PER_RUN=0
# Logging: rotating logs directory and optional JSON-structured output.
LOG_DIR=logs
LOG_JSON=false
LOCAL_AI_ENABLED=false
LOCAL_AI_ALWAYS_RUN=false
LOCAL_AI_CACHE_TTL_DAYS=365
LOCAL_AI_TOP_N=20
LOCAL_AI_MIN_SCORE=0.12
LOCAL_AI_TIMEOUT_SECONDS=600
LOCAL_AI_MODELS_DIR=models/local_ai
CLAP_MODEL_NAME=laion/clap-htsat-unfused
CLAP_CACHE_DIR=models/local_ai/hf
CLAP_CONCURRENCY=2
CLAP_MAX_SECONDS=30
CLAP_LABEL_SPECS=genre: pop,genre: dance,genre: electronic,genre: house,genre: deep house,genre: tech house,genre: techno,genre: trance,genre: drum and bass,genre: disco,genre: funk,genre: soul,genre: rock,genre: indie,genre: r&b,genre: hip hop,genre: rap,genre: latin,genre: afrobeat,genre: reggae,genre: jazz,genre: acoustic,genre: country,genre: folk,genre: edm,subgenre: dance pop,subgenre: eurodance,subgenre: synth-pop,subgenre: techno,subgenre: trance,subgenre: pop rock,subgenre: indie pop,subgenre: latin pop,subgenre: reggaeton,subgenre: afro house,subgenre: slap house,subgenre: tropical house,subgenre: indie dance,subgenre: commercial pop,mood: upbeat,mood: energetic,mood: happy,mood: calm,mood: relaxing,mood: romantic,mood: melancholic,mood: dramatic,mood: confident,mood: playful,mood: elegant,mood: intense,mood: chillout,mood: warm,mood: bright,mood: dark,mood: smooth,valence: positive,valence: neutral,valence: negative,danceability: high,danceability: medium,danceability: low,energy: high,energy: medium,energy: low,occasion: retail background,occasion: busy store,occasion: premium atmosphere,occasion: calm store,occasion: party,occasion: morning,occasion: evening,occasion: weekend,occasion: family friendly,occasion: youth audience,occasion: luxury retail,occasion: grocery store,occasion: fashion store,occasion: restaurant,occasion: workout,weather: sunny,weather: rainy,weather: cloudy,weather: cold,weather: warm,season: summer,season: spring,season: autumn,season: winter,season: christmas,age_group: youth,age_group: adult,age_group: family,age_group: mature,instrument: piano,instrument: guitar,instrument: drums,instrument: bass,instrument: percussion,instrument: electronic beat,instrument: synthesizer,instrument: strings,instrument: acoustic guitar,instrument: electric guitar,instrument: keyboard,instrument: brass,instrument: saxophone,vocals: vocal,vocals: instrumental,vocals: female vocal,vocals: male vocal,language: English,language: Spanish,language: French,language: German
ESSENTIA_DISCOGS_EMBEDDING_MODEL=models/local_ai/discogs-effnet-embeddings.pb
ESSENTIA_DISCOGS_PREDICTION_MODEL=models/local_ai/genre_discogs400-discogs-effnet.pb
ESSENTIA_DISCOGS_LABELS=models/local_ai/discogs-effnet-labels.txt
MUSICNN_MTG_JAMENDO_MODEL=models/local_ai/mtg_jamendo_musicnn.pb
MUSICNN_MTG_JAMENDO_LABELS=models/local_ai/mtg_jamendo_labels.txt
# Extra Discogs-EffNet prediction heads (shared embedding): model|labels[|output], comma-separated.
# These add mood/theme + instrument values off the SAME embedding as genre, so the
# Discogs-EffNet provider fills genre + subgenre + mood/theme + instruments in one pass.
# Missing files are skipped safely. `python scripts/download_models.py` fetches these.
ESSENTIA_EXTRA_HEADS=models/local_ai/mtg_jamendo_moodtheme-discogs-effnet.pb|models/local_ai/mtg_jamendo_moodtheme-labels.txt,models/local_ai/mtg_jamendo_instrument-discogs-effnet.pb|models/local_ai/mtg_jamendo_instrument-labels.txt
WEB_SCRAPING_ENABLED=true
WEB_MAX_RESULTS=5
WEB_MAX_QUERIES_PER_FILE=4
WEB_ALLOWED_DOMAINS=tunebat.com,songbpm.com,musicstax.com,songdata.io,getsongbpm.com,getsongkey.com,chosic.com,wikidata.org,wikipedia.org,musicbrainz.org,discogs.com,last.fm,deezer.com,genius.com,allmusic.com,rateyourmusic.com,officialcharts.com,theaudiodb.com,songwhip.com
WEB_SEARCH_ENDPOINT=https://html.duckduckgo.com/html/
ACOUSTID_API_KEY=
FPCALC_PATH=fpcalc
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
LASTFM_API_KEY=
DISCOGS_TOKEN=
DISCOGS_CONSUMER_KEY=
DISCOGS_CONSUMER_SECRET=
GENIUS_CLIENT_ID=
GENIUS_CLIENT_SECRET=
GENIUS_ACCESS_TOKEN=
LOCAL_AI_HOST_DIR=D:/editorBackend/tag_ai
# Paid provider is intentionally paused by default. Fill these and add
# `sonoteller` to PAID_STAGE_PROVIDERS only when paid analysis is approved.
SONOTELLER_RAPIDAPI_KEY=
SONOTELLER_RAPIDAPI_HOST=sonoteller-ai1.p.rapidapi.com
SONOTELLER_BASE_URL=https://sonoteller-ai1.p.rapidapi.com
SONOTELLER_ANALYZE_ENDPOINT=/music
SONOTELLER_INPUT_MODE=url
SONOTELLER_FILE_URL_BASE=
