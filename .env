# Paid AI analysis provider: SONOTELLER via RapidAPI.
# Public RapidAPI examples use host sonoteller-ai1.p.rapidapi.com and JSON payload {"file": "<public audio url>"}.
SONOTELLER_RAPIDAPI_KEY=
SONOTELLER_RAPIDAPI_HOST=sonoteller-ai1.p.rapidapi.com
SONOTELLER_BASE_URL=https://sonoteller-ai1.p.rapidapi.com
SONOTELLER_ANALYZE_ENDPOINT=/music
SONOTELLER_INPUT_MODE=url
SONOTELLER_FILE_URL_BASE=
LOCAL_AI_HOST_DIR=D:/editorBackend/tag_ai
ESSENTIA_EXTRA_HEADS=models/local_ai/mtg_jamendo_moodtheme-discogs-effnet.pb|models/local_ai/mtg_jamendo_moodtheme-labels.txt,models/local_ai/mtg_jamendo_instrument-discogs-effnet.pb|models/local_ai/mtg_jamendo_instrument-labels.txt
