# Tag Creator runtime configuration.
# Fill API keys/tokens here. Empty providers are skipped safely.

# Input/output
INPUT_DIR=test_media/free_ai_5
OUTPUT_DIR=output
DATA_DIR=data
REPORT_CSV=output/free_ai_5_enrichment_report.csv

# Behavior
DRY_RUN=true
WRITE_TAGS=false
WRITE_COVER_ART=false
RESUME=true
LIMIT=
SUPPORTED_EXTENSIONS=.mp3,.m4a,.mp4,.aac,.flac

# Required tags for "enriched enough" reporting.
REQUIRED_TAGS=title,artist,album,year,genre,subgenre,mood,bpm,key,language,track_number,disc_number,cover_art

# Confidence rules. Metadata below MIN_FIELD_CONFIDENCE is reported but not written.
MIN_FIELD_CONFIDENCE=0.72
MIN_WRITE_CONFIDENCE=0.82
FILL_UNKNOWN_VALUES=false

# Server resource control.
# This limits Python/NumPy/TensorFlow/Essentia thread usage inside the tool.
# Docker can also enforce CPU quota with: docker run --cpus=2 ...
TAG_CREATOR_CPU_THREADS=2

# Provider switches and weights.
ENABLED_PROVIDERS=local_cleanup,itunes,deezer,wikidata,essentia_discogs_effnet,musicnn_mtg_jamendo,web_discovery,rules_inference,sonoteller,acoustid,musicbrainz,spotify,lastfm,discogs,genius,cover_art_archive
PROVIDER_WEIGHTS=local_cleanup:0.70,itunes:0.78,deezer:0.74,wikidata:0.52,essentia_discogs_effnet:0.82,musicnn_mtg_jamendo:0.82,web_discovery:0.58,rules_inference:0.50,sonoteller:0.94,acoustid:0.95,musicbrainz:0.90,spotify:0.82,lastfm:0.62,discogs:0.76,genius:0.45,cover_art_archive:0.80

# Rate limits in seconds between requests per provider.
RATE_LIMITS=local_cleanup:0.00,itunes:0.15,deezer:0.25,wikidata:0.35,essentia_discogs_effnet:0.00,musicnn_mtg_jamendo:0.00,web_discovery:2.00,sonoteller:1.00,musicbrainz:1.10,cover_art_archive:0.25,spotify:0.10,lastfm:0.25,discogs:1.10,acoustid:0.35,genius:0.25

# Hybrid stage control
HYBRID_MODE=true
FREE_STAGE_PROVIDERS=local_cleanup,itunes,deezer,wikidata,acoustid,musicbrainz,spotify,lastfm,discogs,genius,cover_art_archive
LOCAL_AI_STAGE_PROVIDERS=essentia_discogs_effnet,musicnn_mtg_jamendo
WEB_STAGE_PROVIDERS=web_discovery,rules_inference
PAID_STAGE_PROVIDERS=
PAID_ONLY_IF_MISSING=true

# Optional local open-source AI music tagging.
# Keep disabled until the optional dependencies and model files are installed.
LOCAL_AI_ENABLED=true
LOCAL_AI_ALWAYS_RUN=false
LOCAL_AI_CACHE_TTL_DAYS=365
LOCAL_AI_TOP_N=12
LOCAL_AI_MIN_SCORE=0.18
LOCAL_AI_TIMEOUT_SECONDS=600
LOCAL_AI_MODELS_DIR=models/local_ai
ESSENTIA_DISCOGS_EMBEDDING_MODEL=models/local_ai/discogs-effnet-embeddings.pb
ESSENTIA_DISCOGS_PREDICTION_MODEL=models/local_ai/genre_discogs400-discogs-effnet.pb
ESSENTIA_DISCOGS_LABELS=models/local_ai/discogs-effnet-labels.txt
MUSICNN_MTG_JAMENDO_MODEL=models/local_ai/mtg_jamendo_musicnn.pb
MUSICNN_MTG_JAMENDO_LABELS=models/local_ai/mtg_jamendo_labels.txt

# Safe web discovery. This reads public metadata/JSON-LD/meta tags only.
WEB_SCRAPING_ENABLED=true
WEB_MAX_RESULTS=5
WEB_ALLOWED_DOMAINS=tunebat.com,songbpm.com,musicstax.com,songdata.io,getsongbpm.com,wikidata.org,wikipedia.org
WEB_SEARCH_ENDPOINT=https://html.duckduckgo.com/html/

# API keys / tokens
ACOUSTID_API_KEY=
FPCALC_PATH=
SPOTIFY_CLIENT_ID=51090a2c758742849ce9d5ac09a4b9ee
SPOTIFY_CLIENT_SECRET=93dd6999f2fb4299a7d4d57d58b86b7d
LASTFM_API_KEY=656f08d828ce6d4b890801e4fa171eab
LASTFM_SHARED_SECRET=3e8bba5b0d7b23d341dfd0be553f844b
DISCOGS_TOKEN=
DISCOGS_CONSUMER_KEY=GSRKpUwerknWTUJzlCrn
DISCOGS_CONSUMER_SECRET=ItnOoUGjJAVUVCjrRoGibgxQpUIPmQbL
GENIUS_ACCESS_TOKEN=

# Paid AI analysis provider: SONOTELLER via RapidAPI.
# Public RapidAPI examples use host sonoteller-ai1.p.rapidapi.com and JSON payload {"file": "<public audio url>"}.
SONOTELLER_RAPIDAPI_KEY=
SONOTELLER_RAPIDAPI_HOST=sonoteller-ai1.p.rapidapi.com
SONOTELLER_BASE_URL=https://sonoteller-ai1.p.rapidapi.com
SONOTELLER_ANALYZE_ENDPOINT=/music
SONOTELLER_INPUT_MODE=url
SONOTELLER_FILE_URL_BASE=
